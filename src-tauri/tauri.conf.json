{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "idn",
  "version": "1.2.4",
  "identifier": "com.fivood.idn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "贝克街私家侦探档案柜",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFMURGNjg1N0QyNkU0RApSV1JOYnRKWGFOL2hEN2hIZzk3NlpOSTFITEttMERDVmY1TVd6SzB1dG1lQVNFVm5TTVU2akw3Two=",
      "endpoints": [
        "https://github.com/fivood/idn/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
